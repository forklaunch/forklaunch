{
  "name": "@forklaunch/blueprint-iam-base",
  "version": "0.1.5",
  "description": "Forklaunch IAM Implementation",
  "homepage": "https://github.com/forklaunch/forklaunch-js#readme",
  "bugs": {
    "url": "https://github.com/forklaunch/forklaunch-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forklaunch/forklaunch-js.git"
  },
  "license": "MIT",
  "author": "Forklift Technologies, Inc.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsgo -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo pnpm.lock.yaml node_modules",
    "dev": "DOTENV_FILE_PATH=.env.local pnpm run migrate:up && DOTENV_FILE_PATH=.env.local pnpm tsx watch server.ts",
    "dev:bun": "DOTENV_FILE_PATH=.env.local bun run migrate:up && DOTENV_FILE_PATH=.env.local bun --watch server.ts",
    "docs": "typedoc --out docs *",
    "format": "prettier --ignore-path=.prettierignore --config .prettierrc '**/*.{ts,tsx,json}' --write",
    "lint": "eslint . -c eslint.config.mjs",
    "lint:fix": "eslint . -c eslint.config.mjs --fix",
    "migrate:create": "NODE_OPTIONS='--import=tsx' mikro-orm migration:create",
    "migrate:down": "NODE_OPTIONS='--import=tsx' mikro-orm migration:down",
    "migrate:init": "NODE_OPTIONS='--import=tsx' mikro-orm migration:create --initial",
    "migrate:up": "NODE_OPTIONS='--import=tsx' mikro-orm migration:up",
    "prepack": "pnpm run build",
    "retention:enforce": "pnpm tsx scripts/enforce-retention.ts",
    "seed": "DOTENV_FILE_PATH=.env.local NODE_OPTIONS='--import=tsx' mikro-orm seeder:run",
    "start": "node --import=tsx dist/server.js",
    "start:bun": "bun run migrate:up && bun dist/server.js",
    "test": "NODE_OPTIONS='--import=tsx' vitest --passWithNoTests"
  },
  "dependencies": {
    "@forklaunch/blueprint-core": "workspace:*",
    "@forklaunch/blueprint-monitoring": "workspace:*",
    "@forklaunch/core": "^1.1.4",
    "@forklaunch/hyper-express-fork": "^6.17.35",
    "@forklaunch/implementation-iam-base": "workspace:*",
    "@forklaunch/interfaces-iam": "workspace:*",
    "@forklaunch/validator": "^1.1.4",
    "@mikro-orm/core": "7.0.5",
    "@mikro-orm/migrations": "7.0.5",
    "@mikro-orm/mongodb": "7.0.5",
    "@mikro-orm/mysql": "7.0.5",
    "@mikro-orm/postgresql": "7.0.5",
    "@mikro-orm/seeder": "7.0.5",
    "@mikro-orm/sqlite": "7.0.5",
    "@sinclair/typebox": "^0.34.48",
    "@types/uuid": "^11.0.0",
    "dotenv": "^17.3.1",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@forklaunch/testing": "^1.1.4",
    "@mikro-orm/cli": "7.0.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/qs": "^6.15.0",
    "@typescript/native-preview": "7.0.0-dev.20260320.1",
    "depcheck": "^1.4.7",
    "ioredis": "^5.10.1",
    "prettier": "^3.8.1",
    "testcontainers": "^11.13.0",
    "typedoc": "^0.28.18",
    "vitest": "^4.1.1"
  },
  "mikro-orm": {
    "configPaths": [
      "./mikro-orm.config.ts",
      "./dist/mikro-orm.config.js"
    ]
  }
}
